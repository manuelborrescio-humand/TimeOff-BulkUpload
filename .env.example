# Configuración por cliente
# Patrón: CLIENT_{SLUG}_API_KEY, CLIENT_{SLUG}_JWT_TOKEN, CLIENT_{SLUG}_NAME
# El SLUG se usa en la URL: /{slug}

# Ejemplo:
# CLIENT_KORVO_API_KEY=NjE0MzcyODpWbWVjZ0IxSTBSbTVIODlEdC00OFdKcUp3UUYtb3luMA==
# CLIENT_KORVO_JWT_TOKEN=eyJhbGciOiJSUzI1NiIs...
# CLIENT_KORVO_NAME=Korvo AI
